{
  "name": "AdagIO Landing Page",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "concurrently -n astro,cms -c blue,green \"astro dev\" \"decap-server\"",
    "dev:astro": "astro dev",
    "cms": "decap-server",
    "dev:subdomain": "astro dev --host 0.0.0.0 --port 4321",
    "build": "NODE_ENV=production astro build",
    "preview": "astro preview",
    "astro": "astro",
    "build:main": "ASTRO_SITE=https://adagi0.com astro build",
    "build:demos": "ASTRO_SITE=https://demos.adagi0.com astro build",
    "build:all": "npm run build:main && npm run build:demos"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/netlify": "^7.0.12",
    "@astrojs/react": "^5.0.7",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.5",
    "gsap": "^3.15.0",
    "online-3d-viewer": "^0.18.0",
    "particlesjs": "^2.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "scrollreveal": "^4.0.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/scrollreveal": "^0.0.11",
    "concurrently": "^10.0.3",
    "decap-server": "^3.9.0"
  }
}
