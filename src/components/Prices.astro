const tabs = Object.keys(pricingData);
---

<section class="w-full bg-white py-24 px-4" id="precios">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center justify-center px-4 py-1.5 rounded-full bg-indigo-50 border border-indigo-100 mb-6">
        <span class="text-indigo-600 text-xs font-bold uppercase tracking-widest">Precios Transparentes</span>
      </div>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-gray-900 mb-5 leading-tight">
        Servicios a precios
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600"> accesibles</span>
      </h2>
      <p class="text-gray-500 text-lg max-w-xl mx-auto leading-relaxed">
        Sin letras pequeñas. Precios fijos por proyecto, soporte incluido y entregas en tiempo.
      </p>
    </div>

    <!-- Tab pills -->
    <div class="flex justify-center mb-14">
      <div class="inline-flex p-1 bg-gray-100 rounded-2xl gap-1" id="price-tabs" role="tablist">
        {tabs.map((tab, i) => (
          <button
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            aria-controls={`panel-${i}`}
            id={`tab-${i}`}
            data-idx={i}
            class={`
              price-tab px-5 sm:px-7 py-2.5 rounded-xl text-sm font-semibold
              transition-all duration-300
              ${i === 0
                ? 'bg-white text-gray-900 shadow-sm shadow-gray-200'
                : 'text-gray-500 hover:text-gray-800'}
            `}
          >
            {tab}
          </button>
        ))}
      </div>
    </div>

    <!-- Panels -->
    <div class="relative">
      {Object.entries(pricingData).map(([category, plans], panelIdx) => (
        <div
          id={`panel-${panelIdx}`}
          role="tabpanel"
          aria-labelledby={`tab-${panelIdx}`}
          class={`price-panel grid grid-cols-1 md:grid-cols-3 gap-6 transition-all duration-300
            ${panelIdx === 0 ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-4 absolute inset-0 pointer-events-none'}`}
        >
          {plans.map(plan => (
            <div class={`
              relative flex flex-col rounded-3xl overflow-hidden
              transition-all duration-300
              ${plan.isPopular
                ? 'ring-2 ring-indigo-500 shadow-2xl shadow-indigo-100 scale-[1.02]'
                : 'border border-gray-100 shadow-lg hover:shadow-xl'}
            `}>
              {/* Popular badge */}
              {plan.isPopular && (
                <div class="absolute top-0 left-0 right-0 flex justify-center -translate-y-0">
                  <span class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white text-[11px] font-bold uppercase tracking-widest px-5 py-1.5 rounded-b-xl">
                    ⭐ Más Popular
                  </span>
                </div>
              )}

              {/* Gradient header */}
              <div class={`bg-gradient-to-br ${plan.gradient} p-6 pt-8 ${plan.isPopular ? 'pt-10' : ''}`}>
                <div class="w-12 h-12 bg-white/20 rounded-2xl flex items-center justify-center mb-4">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={plan.icon}/>
                  </svg>
                </div>
                <h3 class="text-2xl font-black text-white mb-1">{plan.title}</h3>
                <p class="text-white/70 text-sm">{plan.description}</p>
              </div>

              {/* Body */}
              <div class="bg-white flex flex-col flex-1 p-6">
                {/* Price */}
                <div class="mb-6 pb-6 border-b border-gray-100">
                  <div class="flex items-end gap-1">
                    <span class="text-xs text-gray-400 mb-1.5">$</span>
                    <span class="text-4xl font-black text-gray-900">{plan.price}</span>
                    <span class="text-gray-400 text-sm mb-1.5 ml-1">MXN</span>
                  </div>
                  <span class="text-xs text-gray-400">{plan.period}</span>
                </div>

                {/* Features */}
                <ul class="space-y-3 mb-6 flex-1">
                  {plan.features.map(f => (
                    <li class="flex items-start gap-2.5 text-sm text-gray-700">
                      <svg class="w-4.5 h-4.5 text-emerald-500 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                      </svg>
                      {f}
                    </li>
                  ))}
                  {plan.notIncluded && plan.notIncluded.map(f => (
                    <li class="flex items-start gap-2.5 text-sm text-gray-400 line-through">
                      <svg class="w-4.5 h-4.5 text-gray-300 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                      </svg>
                      {f}
                    </li>
                  ))}
                </ul>

                {/* CTA */}
                <a
                  href="#ContactoForm"
                  class={`
                    w-full flex items-center justify-center gap-2
                    py-3.5 px-6 rounded-2xl
                    text-sm font-bold transition-all duration-300
                    ${plan.isPopular
                      ? 'bg-gradient-to-r from-indigo-600 to-purple-600 text-white hover:opacity-90 shadow-lg shadow-indigo-200'
                      : 'bg-gray-900 hover:bg-gray-700 text-white'}
                  `}
                >
                  Seleccionar plan
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>

    <!-- Bottom note -->
    <p class="text-center text-gray-400 text-sm mt-20">
      ¿Tienes necesidades específicas?
      <a href="#ContactoForm" class="text-indigo-600 font-semibold hover:underline ml-1">Cotización personalizada →</a>
    </p>

  </div>
</section>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.price-tab');
  const panels  = document.querySelectorAll<HTMLElement>('.price-panel');

  function activateTab(idx: number) {
    tabBtns.forEach((btn, i) => {
      const active = i === idx;
      btn.setAttribute('aria-selected', String(active));
      btn.classList.toggle('bg-white',      active);
      btn.classList.toggle('text-gray-900', active);
      btn.classList.toggle('shadow-sm',     active);
      btn.classList.toggle('shadow-gray-200', active);
      btn.classList.toggle('text-gray-500', !active);
      btn.classList.toggle('hover:text-gray-800', !active);
    });

    panels.forEach((panel, i) => {
      const active = i === idx;
      panel.classList.toggle('opacity-0',         !active);
      panel.classList.toggle('translate-y-4',     !active);
      panel.classList.toggle('absolute',          !active);
      panel.classList.toggle('inset-0',           !active);
      panel.classList.toggle('pointer-events-none',!active);
      panel.classList.toggle('opacity-100',       active);
      panel.classList.toggle('translate-y-0',     active);
    });
  }

  tabBtns.forEach((btn, i) => btn.addEventListener('click', () => activateTab(i)));
</script>
