---
import { getCollection } from 'astro:content';

const all = await getCollection('testimonials');
const testimonials = all
  .filter(t => t.data.approved)
  .sort((a, b) => (b.data.date ?? '').localeCompare(a.data.date ?? ''));

const avgRating = testimonials.length
  ? (testimonials.reduce((n, t) => n + t.data.rating, 0) / testimonials.length).toFixed(1)
  : '5.0';

// Color de avatar determinístico por nombre
const avatarColors = [
  'from-blue-500 to-indigo-600',
  'from-rose-500 to-pink-600',
  'from-emerald-500 to-teal-600',
  'from-amber-500 to-orange-600',
  'from-violet-500 to-purple-600',
  'from-cyan-500 to-sky-600',
];
const colorFor = (name: string) =>
  avatarColors[name.split('').reduce((n, c) => n + c.charCodeAt(0), 0) % avatarColors.length];
---

<section id="testimonios" class="w-full bg-gray-900 py-24 px-4 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff05_1px,transparent_1px),linear-gradient(to_bottom,#ffffff05_1px,transparent_1px)] bg-[size:40px_40px] pointer-events-none"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-white/60 text-xs font-bold uppercase tracking-widest mb-6">
        Testimonios
      </div>
      <h2 class="text-4xl sm:text-5xl font-black text-white mb-5 leading-tight">
        Lo que dicen
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400"> nuestros clientes</span>
      </h2>
      <div class="flex items-center justify-center gap-3 text-gray-400 text-sm">
        <div class="flex gap-0.5">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118l-2.8-2.034c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="font-bold text-white">{avgRating}</span>
        <span>·</span>
        <span>{testimonials.length} reseñas verificadas</span>
      </div>
    </div>

    <!-- Testimonials grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-6 mb-16">
      {testimonials.map(t => (
        <figure class="testimonial-card bg-white/5 backdrop-blur border border-white/10 rounded-3xl p-7 hover:bg-white/[0.08] hover:border-white/20 transition-all duration-300 flex flex-col">
          <!-- Stars + project tag -->
          <div class="flex items-center justify-between mb-4">
            <div class="flex gap-0.5">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class={`w-4 h-4 ${i < t.data.rating ? 'text-amber-400' : 'text-gray-700'}`} viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118l-2.8-2.034c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            {t.data.project && (
              <span class="text-[10px] font-bold uppercase tracking-wider text-gray-500 bg-white/5 px-2.5 py-1 rounded-full border border-white/5">
                {t.data.project}
              </span>
            )}
          </div>

          <blockquote class="text-gray-300 text-sm leading-relaxed flex-1 mb-6">
            "{t.data.text}"
          </blockquote>

          <figcaption class="flex items-center gap-3">
            {t.data.avatar ? (
              <img src={t.data.avatar} alt={t.data.name} class="w-11 h-11 rounded-full object-cover" loading="lazy" />
            ) : (
              <div class={`w-11 h-11 rounded-full bg-gradient-to-br ${colorFor(t.data.name)} flex items-center justify-center text-white font-bold text-sm shrink-0`}>
                {t.data.name.split(' ').map(w => w[0]).slice(0, 2).join('')}
              </div>
            )}
            <div class="min-w-0">
              <p class="text-white font-bold text-sm truncate">{t.data.name}</p>
              <p class="text-gray-500 text-xs truncate">
                {[t.data.role, t.data.company].filter(Boolean).join(' · ')}
              </p>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>

    <!-- Submit CTA -->
    <div class="text-center">
      <button
        id="testimonial-open"
        class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/15 border border-white/20 text-white font-semibold px-8 py-3.5 rounded-2xl transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        ¿Trabajamos juntos? Deja tu testimonio
      </button>
    </div>
  </div>

  <!-- Modal de envío -->
  <div id="testimonial-modal" class="hidden fixed inset-0 z-[200] items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="testimonial-modal-bg"></div>
    <div class="relative bg-white rounded-3xl shadow-2xl w-full max-w-md p-8 max-h-[90vh] overflow-y-auto">
      <button id="testimonial-close" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 text-gray-400" aria-label="Cerrar">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>

      <div id="testimonial-form-wrap">
        <h3 class="text-xl font-bold text-gray-900 mb-1">Comparte tu experiencia</h3>
        <p class="text-gray-500 text-sm mb-6">Tu testimonio será revisado por nuestro equipo antes de publicarse.</p>

        <form name="Testimonio" method="POST" data-netlify="true" id="testimonial-form" class="flex flex-col gap-4">
          <input type="hidden" name="form-name" value="Testimonio" />

          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium text-gray-700">Calificación *</label>
            <div class="flex gap-1" id="star-picker">
              {[1,2,3,4,5].map(n => (
                <button type="button" class="star-btn p-0.5" data-value={n} aria-label={`${n} estrellas`}>
                  <svg class="w-8 h-8 text-amber-400 transition-transform hover:scale-110" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118l-2.8-2.034c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                </button>
              ))}
            </div>
            <input type="hidden" name="Calificacion" id="rating-input" value="5" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="t-name" class="text-sm font-medium text-gray-700">Tu nombre *</label>
            <input required type="text" id="t-name" name="Nombre" class="bg-gray-50 border border-gray-200 rounded-xl p-3 text-sm focus:outline-none focus:border-[#123472]" />
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label for="t-role" class="text-sm font-medium text-gray-700">Puesto</label>
              <input type="text" id="t-role" name="Puesto" placeholder="Ej. Director" class="bg-gray-50 border border-gray-200 rounded-xl p-3 text-sm focus:outline-none focus:border-[#123472]" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="t-company" class="text-sm font-medium text-gray-700">Empresa</label>
              <input type="text" id="t-company" name="Empresa" class="bg-gray-50 border border-gray-200 rounded-xl p-3 text-sm focus:outline-none focus:border-[#123472]" />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="t-email" class="text-sm font-medium text-gray-700">Correo (no se publica) *</label>
            <input required type="email" id="t-email" name="Correo" class="bg-gray-50 border border-gray-200 rounded-xl p-3 text-sm focus:outline-none focus:border-[#123472]" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="t-text" class="text-sm font-medium text-gray-700">Tu testimonio *</label>
            <textarea required id="t-text" name="Testimonio" maxlength="400" placeholder="Cuéntanos cómo fue trabajar con nosotros..." class="bg-gray-50 border border-gray-200 rounded-xl p-3 text-sm h-28 resize-none focus:outline-none focus:border-[#123472]"></textarea>
          </div>

          <button type="submit" class="bg-gray-900 hover:bg-[#123472] text-white font-bold py-3.5 rounded-2xl transition-colors mt-1">
            Enviar testimonio
          </button>
        </form>
      </div>

      <div id="testimonial-thanks" class="hidden text-center py-10">
        <div class="w-16 h-16 mx-auto bg-green-50 rounded-full flex items-center justify-center mb-4">
          <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">¡Gracias!</h3>
        <p class="text-gray-500 text-sm">Tu testimonio fue enviado. Lo revisaremos y publicaremos pronto.</p>
      </div>
    </div>
  </div>
</section>

<script>
  const modal   = document.getElementById('testimonial-modal')!;
  const openBtn = document.getElementById('testimonial-open');
  const open  = () => { modal.classList.remove('hidden'); modal.classList.add('flex'); document.body.style.overflow = 'hidden'; };
  const close = () => { modal.classList.add('hidden'); modal.classList.remove('flex'); document.body.style.overflow = ''; };

  openBtn?.addEventListener('click', open);
  document.getElementById('testimonial-close')?.addEventListener('click', close);
  document.getElementById('testimonial-modal-bg')?.addEventListener('click', close);

  /* Star picker */
  const stars = document.querySelectorAll<HTMLButtonElement>('.star-btn');
  const ratingInput = document.getElementById('rating-input') as HTMLInputElement;
  const paintStars = (value: number) => {
    stars.forEach(s => {
      const svg = s.querySelector('svg')!;
      svg.classList.toggle('text-amber-400', Number(s.dataset.value) <= value);
      svg.classList.toggle('text-gray-200',  Number(s.dataset.value) > value);
    });
  };
  paintStars(5);
  stars.forEach(s => s.addEventListener('click', () => {
    ratingInput.value = s.dataset.value!;
    paintStars(Number(s.dataset.value));
  }));

  /* AJAX submit → thanks state (no page reload) */
  const form = document.getElementById('testimonial-form') as HTMLFormElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    try {
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as any).toString(),
      });
    } catch { /* Netlify forms: fire-and-forget */ }
    document.getElementById('testimonial-form-wrap')?.classList.add('hidden');
    document.getElementById('testimonial-thanks')?.classList.remove('hidden');
    setTimeout(close, 3500);
  });
</script>
