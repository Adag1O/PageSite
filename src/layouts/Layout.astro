---
import "../styles/global.css";
import EndPage from "../components/SingleComponent/EndPage.astro";
import Loader from "../components/Loader.astro";
import WhatsAppFloat from "../components/SingleComponent/WhatsAppFloat.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "AdagIO | Soluciones Tecnológicas",
  description = "Consultoría de servicios web, desarrollo de apps, dispositivos electrónicos IoT y venta de productos tecnológicos.",
  image = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://adagi0.com");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- Performance hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Theme color -->
    <meta name="theme-color" content="#123472" />

    <!-- Netlify Identity (needed for Decap CMS) -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" defer></script>
  </head>
  <body class="flex flex-col w-full min-h-screen items-center gap-4">
    <Loader />
    <slot />
    <EndPage />
    <WhatsAppFloat />
  </body>
</html>

<!-- Netlify Identity redirect after login -->
<script>
  if (window.netlifyIdentity) {
    (window as any).netlifyIdentity.on("init", (user: any) => {
      if (!user) {
        (window as any).netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>

<style>
  html { background-color: #f5f4f6; }
  html, body { margin: 0; padding: 0; }
</style>
