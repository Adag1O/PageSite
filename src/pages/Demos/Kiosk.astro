<DemoLayout title="Kiosk Digital | AdagIO">

<!-- ══════════ NAVBAR ══════════ -->
<nav id="kiosk-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/Demos" class="flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <span class="text-white font-black text-lg tracking-tight">Kiosk<span class="text-blue-400">OS</span></span>
      </a>

      <!-- Nav links (desktop) -->
      <div class="hidden md:flex items-center gap-8">
        {["Características","Modelos","Capacidades","Sectores","Integraciones","Precios"].map((l, i) => (
          <a href={`#${["features","models","addons","usecases","integrations","pricing"][i]}`}
             class="text-gray-400 hover:text-white text-sm font-medium transition-colors">
            {l}
          </a>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex items-center gap-3">
        <a href="#pricing" class="hidden sm:block text-gray-400 hover:text-white text-sm font-medium transition-colors">Ver precios</a>
        <a href="#contact-section" class="px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl transition-colors">
          Solicitar demo
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- ══════════ HERO ══════════ -->
<section class="relative min-h-screen bg-gray-950 flex items-center overflow-hidden pt-16">
  <!-- Background -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff05_1px,transparent_1px),linear-gradient(to_bottom,#ffffff05_1px,transparent_1px)] bg-[size:40px_40px]"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-600/15 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-indigo-600/10 blur-[100px] rounded-full"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full py-20">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: copy -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-600/10 border border-blue-500/20 mb-8">
          <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
          <span class="text-blue-300 text-xs font-semibold uppercase tracking-widest">Producto disponible en México</span>
        </div>

        <h1 class="text-5xl sm:text-6xl font-black text-white leading-tight tracking-tight mb-6">
          El kiosk digital<br/>
          <span class="bg-gradient-to-r from-blue-400 via-indigo-400 to-violet-400 bg-clip-text text-transparent">
            que tu negocio<br/>necesita
          </span>
        </h1>

        <p class="text-xl text-gray-400 leading-relaxed mb-8 max-w-lg">
          Pantallas táctiles industriales con software propio, actualizaciones remotas, pagos integrados y analytics en tiempo real. Del lobby a la tienda, del hospital al aeropuerto.
        </p>

        <div class="flex flex-wrap gap-4 mb-12">
          <a href="#contact-section" class="px-7 py-3.5 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-2xl transition-all hover:-translate-y-0.5 shadow-lg shadow-blue-600/30">
            Cotizar ahora
          </a>
          <a href="#features" class="px-7 py-3.5 bg-white/5 hover:bg-white/10 border border-white/10 text-white font-semibold rounded-2xl transition-colors">
            Ver características
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 pt-8 border-t border-white/8">
          {[["350+","Instalaciones activas"],["99.7%","Uptime garantizado"],["24/7","Soporte técnico"]].map(([n,l]) => (
            <div>
              <p class="text-2xl font-black text-white">{n}</p>
              <p class="text-gray-500 text-xs mt-0.5 leading-tight">{l}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: kiosk simulator -->
      <div class="flex justify-center lg:justify-end">
        <div class="kiosk-frame relative flex-shrink-0" style="width: min(300px, 85vw);">
          <!-- Side buttons -->
          <div class="absolute -left-2.5 top-24 flex flex-col gap-2 z-10">
            <div class="w-1.5 h-8 bg-gray-600 rounded-l-sm"></div>
            <div class="w-1.5 h-8 bg-gray-600 rounded-l-sm"></div>
          </div>
          <div class="absolute -right-2.5 top-32 z-10">
            <div class="w-1.5 h-10 bg-gray-600 rounded-r-sm"></div>
          </div>

          <!-- Outer bezel -->
          <div class="bg-gradient-to-b from-gray-700 via-gray-800 to-gray-900 rounded-[2.5rem] p-3 shadow-2xl ring-1 ring-white/10"
               style="box-shadow: 0 0 0 1px rgba(255,255,255,0.07), 0 40px 80px -20px rgba(0,0,0,0.8), inset 0 1px 0 rgba(255,255,255,0.1);">

            <!-- Top bar -->
            <div class="flex items-center justify-between px-4 py-2 mb-1">
              <div class="flex items-center gap-1.5">
                <div class="w-2 h-2 rounded-full bg-gray-600"></div>
                <span class="text-gray-500 text-[9px] font-mono">KioskOS</span>
              </div>
              <div class="w-3 h-3 rounded-full bg-gray-900 ring-1 ring-gray-700 flex items-center justify-center">
                <div class="w-1.5 h-1.5 rounded-full bg-gray-800 ring-1 ring-gray-600"></div>
              </div>
              <div class="flex items-center gap-1.5">
