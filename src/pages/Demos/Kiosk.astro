            <div>
              <label class="text-gray-400 text-xs font-semibold uppercase tracking-wider block mb-1.5">Empresa</label>
              <input type="text" placeholder="Empresa S.A." class="w-full bg-gray-800 border border-white/5 focus:border-blue-500/50 rounded-xl p-3 text-sm text-white outline-none transition-colors placeholder:text-gray-600"/>
