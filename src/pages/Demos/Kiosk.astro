<!-- ══════════ SCRIPTS ══════════ -->
<script>
  // Clock
  function updateClock() {
    const now = new Date();
    const hh = String(now.getHours()).padStart(2,'0');
    const mm = String(now.getMinutes()).padStart(2,'0');
    const days = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
    const months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
    const ts = `${hh}:${mm}`;
    const ds = `${days[now.getDay()]} ${now.getDate()} ${months[now.getMonth()]}`;
    ['kiosk-time','saver-time'].forEach(id => { const el = document.getElementById(id); if(el) el.textContent = ts; });
    ['kiosk-date','saver-date'].forEach(id => { const el = document.getElementById(id); if(el) el.textContent = ds; });
  }
  updateClock();
  setInterval(updateClock, 10000);

  // Nav scroll style
  const nav = document.getElementById('kiosk-nav')!;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav.style.background = 'rgba(3,7,18,0.85)';
      nav.style.backdropFilter = 'blur(16px)';
      nav.style.borderBottom = '1px solid rgba(255,255,255,0.06)';
    } else {
      nav.style.background = 'transparent';
      nav.style.backdropFilter = '';
      nav.style.borderBottom = '';
    }
  }, { passive: true });

  // Kiosk slide navigation
  let currentSlide = 'slide-screensaver';

  function showSlide(id: string) {
    document.querySelectorAll<HTMLElement>('.kiosk-slide').forEach(s => {
      s.style.opacity = '0';
      s.style.transform = 'scale(0.97)';
      setTimeout(() => { s.classList.add('hidden'); s.classList.remove('flex'); }, 220);
    });
    const target = document.getElementById(id);
    if (target) {
      setTimeout(() => {
        target.classList.remove('hidden');
        target.classList.add('flex');
        requestAnimationFrame(() => {
          target.style.opacity = '0';
          target.style.transform = 'scale(1.02)';
          requestAnimationFrame(() => {
            target.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
            target.style.opacity = '1';
            target.style.transform = 'scale(1)';
          });
        });
      }, 230);
    }
    currentSlide = id;
    resetIdleTimer();
  }

  // Idle screensaver
  let idleTimer: ReturnType<typeof setTimeout>;
  function resetIdleTimer() {
    clearTimeout(idleTimer);
    if (currentSlide !== 'slide-screensaver') {
      idleTimer = setTimeout(() => showSlide('slide-screensaver'), 30000);
    }
  }

  // Ripple
  function addRipple(e: PointerEvent, el: HTMLElement) {
    const rect = el.getBoundingClientRect();
    const r = document.createElement('span');
    const size = Math.max(rect.width, rect.height);
    r.style.cssText = `position:absolute;border-radius:50%;background:rgba(255,255,255,0.22);width:${size}px;height:${size}px;left:${e.clientX-rect.left-size/2}px;top:${e.clientY-rect.top-size/2}px;transform:scale(0);animation:ripple-anim 0.5s ease-out forwards;pointer-events:none;z-index:99;`;
    el.style.position = 'relative';
    el.style.overflow = 'hidden';
    el.appendChild(r);
    setTimeout(() => r.remove(), 600);
  }

  // Wire buttons
  document.querySelectorAll<HTMLElement>('.kiosk-btn').forEach(btn => {
    btn.addEventListener('pointerdown', e => addRipple(e as PointerEvent, btn));
    btn.addEventListener('click', () => { const t = btn.dataset.target; if(t) showSlide(t); });
  });

  // Catalog filter
  document.querySelectorAll<HTMLElement>('.cat-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cat-filter').forEach(b => { b.classList.remove('bg-rose-500','text-white'); b.classList.add('bg-gray-100','text-gray-500'); });
      btn.classList.add('bg-rose-500','text-white'); btn.classList.remove('bg-gray-100','text-gray-500');
      const f = btn.dataset.filter;
      document.querySelectorAll<HTMLElement>('.catalog-item').forEach(c => { c.style.display = (!f||f==='Todos'||c.dataset.cat===f)?'':'none'; });
    });
  });

  // Product detail
  document.querySelectorAll<HTMLElement>('.catalog-item').forEach(card => {
    card.addEventListener('click', () => {
      const title = document.getElementById('product-title'); const name = document.getElementById('product-name');
      const price = document.getElementById('product-price'); const img = document.getElementById('product-img') as HTMLImageElement;
      if(title) title.textContent = card.dataset.name||''; if(name) name.textContent = card.dataset.name||'';
      if(price) price.textContent = card.dataset.price||''; if(img){ img.src=card.dataset.img||''; img.alt=card.dataset.name||''; }
    });
  });

  // Subject opts
  document.querySelectorAll<HTMLElement>('.subject-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.subject-opt').forEach(b => { b.classList.remove('bg-emerald-500','text-white','border-emerald-500'); b.classList.add('bg-gray-50','text-gray-600','border-gray-200'); });
      btn.classList.add('bg-emerald-500','text-white','border-emerald-500'); btn.classList.remove('bg-gray-50','text-gray-600','border-gray-200');
    });
  });

  // Kiosk contact form
  document.getElementById('kiosk-send')?.addEventListener('click', () => {
    const form = document.getElementById('contact-form')!; const success = document.getElementById('contact-success')!;
    form.style.opacity='0';
    setTimeout(() => { form.style.display='none'; success.classList.remove('hidden'); success.classList.add('flex'); success.style.opacity='0'; requestAnimationFrame(()=>{ success.style.transition='opacity 0.3s'; success.style.opacity='1'; }); }, 250);
    setTimeout(() => { form.style.display=''; form.style.opacity='1'; success.classList.add('hidden'); success.classList.remove('flex'); }, 5000);
  });

  // Main contact form
  document.getElementById('main-send-btn')?.addEventListener('click', () => {
    const form = document.getElementById('main-contact-form')!; const success = document.getElementById('main-contact-success')!;
    form.style.opacity='0';
    setTimeout(() => { form.style.display='none'; success.classList.remove('hidden'); success.classList.add('flex'); success.style.opacity='0'; requestAnimationFrame(()=>{ success.style.transition='opacity 0.3s'; success.style.opacity='1'; }); }, 250);
  });

  // Init
  showSlide('slide-screensaver');
  resetIdleTimer();
</script>

<style>
  @keyframes ripple-anim { to { transform:scale(3); opacity:0; } }
  .kiosk-slide { transition: opacity 0.25s ease, transform 0.25s ease; }
  .kiosk-slide ::-webkit-scrollbar { width:2px; }
  .kiosk-slide ::-webkit-scrollbar-thumb { background:rgba(0,0,0,0.12); border-radius:2px; }
  html { scroll-behavior: smooth; }
</style>

