        <h3 class="text-white font-bold text-lg mb-6">Solicitar información</h3>
        <div class="space-y-4" id="main-contact-form">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="text-gray-400 text-xs font-semibold uppercase tracking-wider block mb-1.5">Nombre</label>
              <input type="text" placeholder="Tu nombre" class="w-full bg-gray-800 border border-white/5 focus:border-blue-500/50 rounded-xl p-3 text-sm text-white outline-none transition-colors placeholder:text-gray-600"/>
