            <textarea placeholder="Cuéntanos sobre tu proyecto…" rows="3" class="w-full bg-gray-800 border border-white/5 focus:border-blue-500/50 rounded-xl p-3 text-sm text-white outline-none transition-colors resize-none placeholder:text-gray-600"></textarea>
          </div>
          <button id="main-send-btn" class="w-full py-3.5 bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white font-bold rounded-xl transition-colors flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
