---
import DemoLayout from '../../layouts/DemoLayout.astro';

const links = [
  {
    label: 'Sitio web oficial',
    sublabel: 'adagi0.com',
    href: 'https://adagi0.com',
    color: 'from-violet-600 to-indigo-600',
    glow: 'rgba(124,58,237,0.4)',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>`,
  },
  {
    label: 'GitHub',
    sublabel: 'Proyectos de código abierto',
    href: 'https://github.com/Adag1O',
    color: 'from-gray-700 to-gray-900',
    glow: 'rgba(55,65,81,0.5)',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
  },
  {
    label: 'Instagram',
    sublabel: '@adagio.mx',
    href: '#',
    color: 'from-pink-600 via-rose-500 to-orange-500',
    glow: 'rgba(236,72,153,0.4)',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    sublabel: 'Conecta profesionalmente',
    href: '#',
    color: 'from-blue-600 to-blue-800',
    glow: 'rgba(37,99,235,0.4)',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'Contáctanos',
    sublabel: 'contacto@adagi0.com',
    href: 'mailto:contacto@adagi0.com',
    color: 'from-emerald-500 to-teal-600',
    glow: 'rgba(16,185,129,0.4)',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
];

const stats = [
  { value: '50+', label: 'Proyectos' },
  { value: '5★', label: 'Calificación' },
  { value: '3+', label: 'Años' },
];
---

<DemoLayout title="AdagIO - Links">
  <div class="relative min-h-screen overflow-hidden" id="lt-root">

    <!-- Animated gradient background -->
    <div class="absolute inset-0 bg-gray-950">
      <div class="absolute inset-0 opacity-60" id="bg-gradient" style="background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(124,58,237,0.35) 0%, transparent 60%), radial-gradient(ellipse 60% 50% at 80% 100%, rgba(16,185,129,0.2) 0%, transparent 60%), radial-gradient(ellipse 50% 40% at 10% 80%, rgba(236,72,153,0.2) 0%, transparent 60%);"></div>
      <!-- Grid pattern -->
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 40px 40px;"></div>
    </div>

    <!-- Floating orbs -->
    <div class="absolute top-20 right-10 w-64 h-64 rounded-full bg-violet-600/10 blur-3xl animate-pulse" style="animation-duration:4s;"></div>
    <div class="absolute bottom-20 left-10 w-48 h-48 rounded-full bg-emerald-500/10 blur-3xl animate-pulse" style="animation-duration:6s; animation-delay:2s;"></div>

    <!-- Content -->
    <div class="relative z-10 min-h-screen flex flex-col items-center justify-center px-4 py-12 sm:py-16">
      <div class="w-full max-w-md mx-auto">

        <!-- Profile card -->
        <div class="text-center mb-8 link-item" style="--delay:0ms;">
          <div class="relative inline-block mb-4">
            <!-- Animated ring -->
            <div class="absolute inset-0 rounded-full bg-gradient-to-r from-violet-600 via-pink-500 to-emerald-500 blur-sm opacity-70 animate-spin" style="animation-duration:4s; margin:-3px;"></div>
            <div class="relative w-24 h-24 rounded-full bg-gradient-to-br from-violet-600 to-indigo-700 flex items-center justify-center text-3xl font-bold text-white shadow-2xl border-2 border-gray-950">
              A
            </div>
          </div>

          <h1 class="text-2xl sm:text-3xl font-bold text-white mb-1">AdagIO</h1>
          <p class="text-gray-400 text-sm mb-3">Consultoría Digital & Soluciones IoT</p>

          <!-- Tags -->
          <div class="flex flex-wrap justify-center gap-2 mb-5">
            {['🚀 Web', '🔌 IoT', '💡 Innovación'].map(tag => (
              <span class="text-xs bg-white/8 border border-white/10 text-gray-300 px-3 py-1 rounded-full">{tag}</span>
            ))}
          </div>

          <!-- Stats -->
          <div class="flex justify-center gap-6 py-4 border-y border-white/8">
            {stats.map(s => (
              <div class="text-center">
                <p class="text-xl font-bold text-white">{s.value}</p>
                <p class="text-gray-500 text-xs">{s.label}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Links -->
        <div class="flex flex-col gap-3 mb-8">
          {links.map((link, i) => (
            <a
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class={`link-item link-card relative flex items-center gap-4 w-full px-4 py-3.5 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm hover:border-white/20 transition-all duration-300 group overflow-hidden`}
              style={`--delay:${(i + 1) * 80}ms; --glow:${link.glow};`}
              data-href={link.href}
            >
              <!-- Gradient bg on hover -->
              <div class={`absolute inset-0 bg-gradient-to-r ${link.color} opacity-0 group-hover:opacity-10 transition-opacity duration-300`}></div>

              <!-- Icon -->
              <div class={`relative flex-shrink-0 w-10 h-10 rounded-xl bg-gradient-to-br ${link.color} flex items-center justify-center text-white shadow-lg`}>
                <Fragment set:html={link.icon} />
              </div>

              <!-- Text -->
              <div class="flex-1 min-w-0 relative">
                <p class="text-white font-medium text-sm truncate">{link.label}</p>
                <p class="text-gray-400 text-xs truncate">{link.sublabel}</p>
              </div>

              <!-- Arrow -->
              <div class="relative text-gray-500 group-hover:text-white group-hover:translate-x-0.5 transition-all duration-200">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>

              <!-- Click ripple indicator -->
              <div class="link-ripple absolute inset-0 rounded-2xl border border-white/0 transition-all duration-500"></div>
            </a>
          ))}
        </div>

        <!-- Share -->
        <div class="link-item text-center" style={`--delay:${(links.length + 1) * 80}ms;`}>
          <button id="shareBtn" class="inline-flex items-center gap-2 text-xs text-gray-500 hover:text-gray-300 transition-colors py-2 px-4 rounded-full border border-white/8 hover:border-white/20">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
            </svg>
            Compartir perfil
          </button>
          <p id="shareFeedback" class="text-xs text-emerald-400 mt-2 opacity-0 transition-opacity duration-300">¡Enlace copiado!</p>
        </div>

        <!-- Footer -->
        <div class="link-item text-center mt-8" style={`--delay:${(links.length + 2) * 80}ms;`}>
          <p class="text-gray-600 text-xs">
            Hecho con ❤️ por <a href="https://adagi0.com" target="_blank" class="text-violet-400 hover:text-violet-300 transition-colors">AdagIO</a>
          </p>
          <p class="text-gray-700 text-xs mt-1">© {new Date().getFullYear()} Todos los derechos reservados</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ── Entrance animations ────────────────────────────────────────────────────
    const items = document.querySelectorAll<HTMLElement>('.link-item');
    items.forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    });

    requestAnimationFrame(() => {
      items.forEach(el => {
        const delay = parseInt(el.style.getPropertyValue('--delay') || '0');
        setTimeout(() => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, delay + 100);
      });
    });

    // ── Click ripple effect ────────────────────────────────────────────────────
    document.querySelectorAll('.link-card').forEach(card => {
      card.addEventListener('click', () => {
        const ripple = card.querySelector('.link-ripple') as HTMLElement;
        if (ripple) {
          ripple.style.borderColor = 'rgba(255,255,255,0.4)';
          ripple.style.transform = 'scale(1.02)';
          setTimeout(() => {
            ripple.style.borderColor = 'rgba(255,255,255,0)';
            ripple.style.transform = 'scale(1)';
          }, 300);
        }
      });
    });

    // ── Share button ───────────────────────────────────────────────────────────
    document.getElementById('shareBtn')?.addEventListener('click', async () => {
      const url = window.location.href;
      const feedback = document.getElementById('shareFeedback')!;

      try {
        if (navigator.share) {
          await navigator.share({ title: 'AdagIO Links', url });
        } else {
          await navigator.clipboard.writeText(url);
          feedback.style.opacity = '1';
          setTimeout(() => { feedback.style.opacity = '0'; }, 2000);
        }
      } catch {
        await navigator.clipboard.writeText(url).catch(() => {});
        feedback.style.opacity = '1';
        setTimeout(() => { feedback.style.opacity = '0'; }, 2000);
      }
    });

    // ── Animated background drift ──────────────────────────────────────────────
    let t = 0;
    const bg = document.getElementById('bg-gradient');
    function animateBg() {
      t += 0.003;
      if (bg) {
        const x = 50 + Math.sin(t) * 10;
        const y = -10 + Math.cos(t * 0.7) * 8;
        bg.style.background = `radial-gradient(ellipse 80% 60% at ${x}% ${y}%, rgba(124,58,237,0.35) 0%, transparent 60%), radial-gradient(ellipse 60% 50% at 80% 100%, rgba(16,185,129,0.2) 0%, transparent 60%), radial-gradient(ellipse 50% 40% at 10% 80%, rgba(236,72,153,0.2) 0%, transparent 60%)`;
      }
      requestAnimationFrame(animateBg);
    }
    animateBg();
  </script>

  <style>
    html { background: #030712; }
    .link-card:hover {
      box-shadow: 0 0 20px var(--glow, rgba(124,58,237,0.3)), 0 4px 24px rgba(0,0,0,0.3);
      transform: translateY(-1px);
    }
  </style>
</DemoLayout>
