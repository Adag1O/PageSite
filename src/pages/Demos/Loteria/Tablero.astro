---
import DemoLayout from "../../../layouts/DemoLayout.astro";
const { isDemoSubdomain } = Astro.locals;
const cartasUrl = isDemoSubdomain ? '/Loteria/Cartas' : '/Demos/Loteria/Cartas';

const allCartas = [
  {id:1,name:"El Gallo"},{id:2,name:"El Diablo"},{id:3,name:"La Dama"},{id:4,name:"El Catrin"},
  {id:5,name:"El Paraguas"},{id:6,name:"La Sirena"},{id:7,name:"La Escalera"},{id:8,name:"La Botella"},
  {id:9,name:"El Barril"},{id:10,name:"El Arbol"},{id:11,name:"El Melon"},{id:12,name:"El Valiente"},
  {id:13,name:"El Gorrito"},{id:14,name:"La Muerte"},{id:15,name:"La Pera"},{id:16,name:"La Bandera"},
  {id:17,name:"El Bandolon"},{id:18,name:"El Violoncello"},{id:19,name:"La Garza"},{id:20,name:"El Pajaro"},
];

// Pick 16 random for the board
const shuffled = [...allCartas].sort(() => Math.random() - 0.5).slice(0, 16);
---

<DemoLayout title="Lotería - Tablero">
  <div class="min-h-screen bg-gradient-to-br from-amber-950 via-red-950 to-gray-950 flex flex-col" id="loteria-root">

    <!-- Header -->
    <header class="flex items-center justify-between px-4 py-3 bg-black/30 border-b border-white/10 backdrop-blur-sm">
      <div class="flex items-center gap-2">
        <span class="text-2xl">🎴</span>
        <div>
          <p class="text-white font-bold text-sm leading-tight">Lotería Mexicana</p>
          <p class="text-amber-400 text-xs">Tu tablero</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div id="statusBadge" class="px-3 py-1 bg-amber-500/20 border border-amber-500/30 text-amber-300 text-xs rounded-full font-medium">
          Esperando…
        </div>
        <a href={cartasUrl} class="px-3 py-1.5 bg-white/10 hover:bg-white/20 border border-white/10 text-white text-xs rounded-xl transition-colors font-medium">
          Mazo de cartas →
        </a>
      </div>
    </header>

    <!-- Board -->
    <main class="flex-1 flex flex-col items-center justify-center p-4">
      <div class="w-full max-w-sm">

        <!-- Score tracker -->
        <div class="flex items-center justify-between mb-4">
          <p class="text-white/60 text-xs">Marcadas: <span id="markedCount" class="text-white font-bold">0</span> / 16</p>
          <button id="resetBtn" class="px-3 py-1.5 bg-white/10 hover:bg-white/20 text-white text-xs rounded-xl transition-colors border border-white/10">
            Reiniciar
          </button>
        </div>

        <!-- Progress bar -->
        <div class="w-full h-1.5 bg-white/10 rounded-full mb-5 overflow-hidden">
          <div id="progressBar" class="h-full bg-gradient-to-r from-amber-400 to-red-400 rounded-full transition-all duration-500" style="width:0%"></div>
        </div>

        <!-- 4×4 Grid -->
        <div class="grid grid-cols-4 gap-2">
          {shuffled.map(carta => (
            <button
              class="loteria-cell relative aspect-[2/3] rounded-xl overflow-hidden border-2 border-amber-900/40 bg-amber-950/30 hover:border-amber-500/60 transition-all duration-200 active:scale-95 group"
              data-id={carta.id}
              data-name={carta.name}
              aria-label={carta.name}
            >
              <!-- Card image -->
              <img
                src={`/Cards/${carta.id}_${carta.name.replace(/ /g,'_')}.avif`}
                alt={carta.name}
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
              <!-- Hover shimmer -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <!-- Marked overlay (frijolito) -->
              <div class="marked-overlay absolute inset-0 bg-amber-900/80 backdrop-blur-sm flex items-center justify-center opacity-0 transition-all duration-300 rounded-xl">
                <span class="text-2xl drop-shadow-lg">🫘</span>
              </div>
            </button>
          ))}
        </div>

        <!-- Bottom hint -->
        <p class="text-white/30 text-xs text-center mt-5">Toca cada carta para marcarla con tu frijolito</p>
      </div>
    </main>

    <!-- Win modal -->
    <div id="winModal" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
      <div class="bg-gradient-to-br from-amber-900 to-red-900 border border-amber-500/40 rounded-3xl p-8 text-center shadow-2xl mx-4 max-w-sm w-full">
        <div class="text-6xl mb-4">🎉</div>
        <h2 class="text-3xl font-black text-white mb-2">¡LOTERÍA!</h2>
        <p class="text-amber-200 text-sm mb-6">¡Completaste tu tablero! ¡Ganaste!</p>
        <button id="playAgain" class="w-full py-3.5 bg-amber-500 hover:bg-amber-400 text-amber-950 font-black rounded-2xl transition-colors text-sm">
          Jugar de nuevo
        </button>
      </div>
    </div>
  </div>

  <script>
    const cells = document.querySelectorAll<HTMLElement>('.loteria-cell');
    const countEl = document.getElementById('markedCount')!;
    const progressEl = document.getElementById('progressBar')!;
    const statusEl = document.getElementById('statusBadge')!;
    const winModal = document.getElementById('winModal')!;
    const resetBtn = document.getElementById('resetBtn')!;
    const playAgain = document.getElementById('playAgain')!;

    let marked = new Set<string>();

    function updateStatus() {
      const n = marked.size;
      countEl.textContent = String(n);
      progressEl.style.width = `${(n / 16) * 100}%`;

      if (n === 0) {
        statusEl.textContent = 'Esperando…';
        statusEl.className = 'px-3 py-1 bg-amber-500/20 border border-amber-500/30 text-amber-300 text-xs rounded-full font-medium';
      } else if (n < 8) {
        statusEl.textContent = `${n} marcadas`;
        statusEl.className = 'px-3 py-1 bg-blue-500/20 border border-blue-500/30 text-blue-300 text-xs rounded-full font-medium';
      } else if (n < 16) {
        statusEl.textContent = `¡Casi!`;
        statusEl.className = 'px-3 py-1 bg-green-500/20 border border-green-500/30 text-green-300 text-xs rounded-full font-medium';
      } else {
        winModal.style.opacity = '1';
        winModal.style.pointerEvents = 'auto';
      }
    }

    cells.forEach(cell => {
      cell.addEventListener('click', () => {
        const id = cell.dataset.id!;
        const overlay = cell.querySelector<HTMLElement>('.marked-overlay')!;
        if (marked.has(id)) {
          marked.delete(id);
          overlay.style.opacity = '0';
          cell.style.borderColor = '';
        } else {
          marked.add(id);
          overlay.style.opacity = '1';
          cell.style.borderColor = 'rgba(245,158,11,0.8)';
        }
        updateStatus();
      });
    });

    const reset = () => {
      marked.clear();
      cells.forEach(cell => {
        cell.querySelector<HTMLElement>('.marked-overlay')!.style.opacity = '0';
        cell.style.borderColor = '';
      });
      winModal.style.opacity = '0';
      winModal.style.pointerEvents = 'none';
      updateStatus();
    };

    resetBtn.addEventListener('click', reset);
    playAgain.addEventListener('click', () => window.location.reload());
  </script>
</DemoLayout>
