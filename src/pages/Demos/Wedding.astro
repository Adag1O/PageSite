---
import DemoLayout from "../../layouts/DemoLayout.astro";
---

<DemoLayout title="Wedding Dreams - María & Carlos">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />

  <!-- Petals canvas -->
  <canvas id="petalsCanvas" class="fixed inset-0 pointer-events-none z-0"></canvas>

  <div class="relative min-h-screen" style="font-family: 'Jost', sans-serif;">

    <!-- Hero Section -->
    <section id="hero" class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="https://images.unsplash.com/photo-1519741497674-611481863552?w=1600&h=900&fit=crop&crop=center&q=80"
          alt="Wedding"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/70"></div>
      </div>

      <div class="relative z-10 text-center text-white px-4 animate-fadeIn">
        <p class="text-xs tracking-[0.4em] uppercase text-rose-200 mb-4">We're getting married</p>
        <h1 class="text-5xl sm:text-7xl md:text-9xl mb-4 text-white" style="font-family:'Cormorant Garamond',serif; font-weight:300; font-style:italic;">
          María & Carlos
        </h1>
        <div class="w-24 h-px bg-rose-300 mx-auto mb-4"></div>
        <p class="text-sm sm:text-base tracking-widest text-rose-100 mb-12">15 · IX · 2025 · Guadalajara, México</p>

        <!-- Countdown -->
        <div id="countdown" class="flex gap-6 sm:gap-10 justify-center mb-12">
          <div class="flex flex-col items-center">
            <span id="cd-days" class="text-3xl sm:text-5xl font-light text-white" style="font-family:'Cormorant Garamond',serif;">--</span>
            <span class="text-[10px] tracking-[0.3em] uppercase text-rose-200 mt-1">Días</span>
          </div>
          <div class="text-3xl sm:text-5xl font-light text-rose-300 self-start mt-1">·</div>
          <div class="flex flex-col items-center">
            <span id="cd-hours" class="text-3xl sm:text-5xl font-light text-white" style="font-family:'Cormorant Garamond',serif;">--</span>
            <span class="text-[10px] tracking-[0.3em] uppercase text-rose-200 mt-1">Horas</span>
          </div>
          <div class="text-3xl sm:text-5xl font-light text-rose-300 self-start mt-1">·</div>
          <div class="flex flex-col items-center">
            <span id="cd-mins" class="text-3xl sm:text-5xl font-light text-white" style="font-family:'Cormorant Garamond',serif;">--</span>
            <span class="text-[10px] tracking-[0.3em] uppercase text-rose-200 mt-1">Min</span>
          </div>
          <div class="text-3xl sm:text-5xl font-light text-rose-300 self-start mt-1">·</div>
          <div class="flex flex-col items-center">
            <span id="cd-secs" class="text-3xl sm:text-5xl font-light text-white" style="font-family:'Cormorant Garamond',serif;">--</span>
            <span class="text-[10px] tracking-[0.3em] uppercase text-rose-200 mt-1">Seg</span>
          </div>
        </div>

        <a href="#ceremony" class="inline-flex flex-col items-center gap-2 text-rose-200 hover:text-white transition-colors group">
          <span class="text-xs tracking-[0.3em] uppercase">Conoce más</span>
          <svg class="w-5 h-5 group-hover:translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
          </svg>
        </a>
      </div>
    </section>

    <!-- Navigation pills -->
    <nav class="sticky top-0 z-30 bg-white/80 backdrop-blur-md border-b border-rose-100 shadow-sm">
      <div class="max-w-2xl mx-auto px-4 flex justify-center gap-1 sm:gap-2 py-3 overflow-x-auto">
        {[
          { href: '#ceremony', label: 'Ceremonia' },
          { href: '#reception', label: 'Recepción' },
          { href: '#gallery', label: 'Galería' },
          { href: '#timeline', label: 'Programa' },
          { href: '#rsvp', label: 'RSVP' },
        ].map(n => (
          <a href={n.href} class="px-3 py-1.5 text-xs sm:text-sm rounded-full text-gray-600 hover:text-rose-600 hover:bg-rose-50 transition-all whitespace-nowrap">
            {n.label}
          </a>
        ))}
      </div>
    </nav>

    <!-- Ceremony Section -->
    <section id="ceremony" class="py-20 sm:py-32 px-4 bg-gradient-to-b from-rose-50 to-white">
      <div class="max-w-2xl mx-auto text-center reveal">
        <p class="text-xs tracking-[0.4em] uppercase text-rose-400 mb-4">La Ceremonia</p>
        <h2 class="text-4xl sm:text-5xl mb-6 text-gray-800" style="font-family:'Cormorant Garamond',serif; font-style:italic;">
          Unidos en Amor
        </h2>
        <div class="w-16 h-px bg-rose-300 mx-auto mb-10"></div>

        <div class="grid sm:grid-cols-2 gap-6 text-left">
          <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-sm border border-rose-100">
            <div class="w-10 h-10 rounded-full bg-rose-100 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <p class="text-xs tracking-wider uppercase text-rose-400 mb-1">Fecha & Hora</p>
            <p class="text-lg font-medium text-gray-800 mb-1">Sábado 15 de Septiembre, 2025</p>
            <p class="text-gray-500 text-sm">4:00 PM</p>
          </div>

          <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-sm border border-rose-100">
            <div class="w-10 h-10 rounded-full bg-rose-100 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <p class="text-xs tracking-wider uppercase text-rose-400 mb-1">Lugar</p>
            <p class="text-lg font-medium text-gray-800 mb-1">Iglesia San Miguel Arcángel</p>
            <p class="text-gray-500 text-sm">Av. Principal 123, Centro Histórico</p>
          </div>
        </div>

        <a
          href="https://maps.google.com"
          target="_blank"
          class="inline-flex items-center gap-2 mt-8 px-6 py-3 bg-rose-500 hover:bg-rose-600 text-white text-sm rounded-full transition-all hover:shadow-lg hover:shadow-rose-200"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          Ver en Google Maps
        </a>
      </div>
    </section>

    <!-- Reception Section -->
    <section id="reception" class="py-20 sm:py-32 px-4 bg-white">
      <div class="max-w-2xl mx-auto text-center reveal">
        <p class="text-xs tracking-[0.4em] uppercase text-rose-400 mb-4">La Recepción</p>
        <h2 class="text-4xl sm:text-5xl mb-6 text-gray-800" style="font-family:'Cormorant Garamond',serif; font-style:italic;">
          La Celebración
        </h2>
        <div class="w-16 h-px bg-rose-300 mx-auto mb-10"></div>

        <div class="bg-gradient-to-br from-rose-50 to-pink-50 rounded-3xl p-8 sm:p-12 border border-rose-100 mb-8">
          <p class="text-2xl sm:text-3xl font-light text-gray-700 mb-2" style="font-family:'Cormorant Garamond',serif;">Salón "El Jardín"</p>
          <p class="text-gray-500 text-sm mb-6">Carretera al Lago Km 5, Zona Residencial</p>
          <p class="text-rose-500 font-medium">7:00 PM — 2:00 AM</p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {[
            { time: '7:00 PM', event: 'Bienvenida' },
            { time: '8:00 PM', event: 'Cena' },
            { time: '9:00 PM', event: 'Primer baile' },
            { time: '10:00 PM', event: 'Baile abierto' },
          ].map(item => (
            <div class="bg-white rounded-2xl p-4 border border-gray-100 shadow-sm text-center">
              <p class="text-xs text-rose-400 font-medium mb-1">{item.time}</p>
              <p class="text-sm text-gray-700 font-medium">{item.event}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Gallery Section -->
    <section id="gallery" class="py-20 sm:py-32 px-4 bg-gray-50">
      <div class="max-w-4xl mx-auto reveal">
        <div class="text-center mb-12">
          <p class="text-xs tracking-[0.4em] uppercase text-rose-400 mb-4">Nuestros Recuerdos</p>
          <h2 class="text-4xl sm:text-5xl text-gray-800" style="font-family:'Cormorant Garamond',serif; font-style:italic;">Galería</h2>
          <div class="w-16 h-px bg-rose-300 mx-auto mt-6"></div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4">
          {[
            { src: 'https://images.unsplash.com/photo-1519741497674-611481863552?w=600&h=600&fit=crop', label: 'La Ceremonia', tall: false },
            { src: 'https://images.unsplash.com/photo-1465495976277-4387d4b0e4a6?w=600&h=800&fit=crop', label: 'La Recepción', tall: true },
            { src: 'https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=600&h=600&fit=crop', label: 'Los Detalles', tall: false },
            { src: 'https://images.unsplash.com/photo-1583939003579-730e3918a45a?w=600&h=600&fit=crop', label: 'Los Recuerdos', tall: false },
            { src: 'https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=600&h=800&fit=crop', label: 'La Celebración', tall: true },
            { src: 'https://images.unsplash.com/photo-1591604466107-ec97de577aff?w=600&h=600&fit=crop', label: 'El Amor', tall: false },
          ].map((img, i) => (
            <div
              class={`relative overflow-hidden rounded-2xl cursor-pointer group gallery-item ${img.tall ? 'row-span-2' : ''}`}
              style={`aspect-ratio: ${img.tall ? '3/4' : '1/1'};`}
              data-src={img.src}
              data-label={img.label}
            >
              <img
                src={img.src}
                alt={img.label}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                <p class="text-white text-sm font-light" style="font-family:'Cormorant Garamond',serif; font-style:italic;">{img.label}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Light box -->
    <div id="lightbox" class="fixed inset-0 z-50 bg-black/90 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
      <button id="lb-close" class="absolute top-4 right-4 text-white/70 hover:text-white transition-colors">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
      <img id="lb-img" src="" alt="" class="max-w-[90vw] max-h-[85vh] object-contain rounded-xl shadow-2xl" />
      <p id="lb-label" class="absolute bottom-6 left-0 right-0 text-center text-white/80 text-lg" style="font-family:'Cormorant Garamond',serif; font-style:italic;"></p>
    </div>

    <!-- Timeline Section -->
    <section id="timeline" class="py-20 sm:py-32 px-4 bg-white">
      <div class="max-w-2xl mx-auto reveal">
        <div class="text-center mb-16">
          <p class="text-xs tracking-[0.4em] uppercase text-rose-400 mb-4">El Gran Día</p>
          <h2 class="text-4xl sm:text-5xl text-gray-800" style="font-family:'Cormorant Garamond',serif; font-style:italic;">Programa</h2>
          <div class="w-16 h-px bg-rose-300 mx-auto mt-6"></div>
        </div>

        <div class="relative">
          <div class="absolute left-1/2 top-0 bottom-0 w-px bg-rose-100 -translate-x-1/2"></div>
          {[
            { time: '4:00 PM', icon: '⛪', title: 'Ceremonia religiosa', desc: 'Intercambio de votos en la Iglesia San Miguel' },
            { time: '5:30 PM', icon: '📸', title: 'Sesión fotográfica', desc: 'Retratos de los novios y familia' },
            { time: '7:00 PM', icon: '🥂', title: 'Bienvenida', desc: 'Cóctel de bienvenida en el jardín' },
            { time: '8:00 PM', icon: '🍽️', title: 'Cena', desc: 'Menú de 3 tiempos para todos los invitados' },
            { time: '9:00 PM', icon: '💃', title: 'Primer baile', desc: 'El vals de los novios' },
            { time: '10:30 PM', icon: '🎂', title: 'Corte del pastel', desc: 'Momento dulce y especial' },
            { time: '11:30 PM', icon: '💐', title: 'Ramo de la novia', desc: 'Tradición especial para las solteras' },
          ].map((item, i) => (
            <div class={`relative flex items-start gap-6 mb-10 ${i % 2 === 0 ? 'flex-row' : 'flex-row-reverse'}`}>
              <div class={`flex-1 ${i % 2 === 0 ? 'text-right' : 'text-left'}`}>
                <p class="text-xs text-rose-400 font-medium tracking-wider mb-1">{item.time}</p>
                <p class="font-medium text-gray-800 mb-1">{item.title}</p>
                <p class="text-sm text-gray-500">{item.desc}</p>
              </div>
              <div class="relative z-10 w-10 h-10 bg-white border-2 border-rose-200 rounded-full flex items-center justify-center flex-shrink-0 shadow-sm text-lg">
                {item.icon}
              </div>
              <div class="flex-1"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- RSVP Section -->
    <section id="rsvp" class="py-20 sm:py-32 px-4 bg-gradient-to-br from-rose-50 via-pink-50 to-white">
      <div class="max-w-lg mx-auto reveal">
        <div class="text-center mb-12">
          <p class="text-xs tracking-[0.4em] uppercase text-rose-400 mb-4">Confirma tu asistencia</p>
          <h2 class="text-4xl sm:text-5xl text-gray-800 mb-4" style="font-family:'Cormorant Garamond',serif; font-style:italic;">
            ¿Nos acompañas?
          </h2>
          <p class="text-gray-500 text-sm">Tu presencia es nuestro mejor regalo. Por favor confirma antes del 1 de septiembre.</p>
          <div class="w-16 h-px bg-rose-300 mx-auto mt-6"></div>
        </div>

        <div id="rsvp-form-wrap" class="bg-white rounded-3xl p-8 shadow-lg border border-rose-100">
          <form id="rsvp-form" class="space-y-5">
            <div>
              <label class="block text-xs font-medium tracking-wider uppercase text-gray-500 mb-2">Nombre completo</label>
              <input type="text" id="rsvp-name" required placeholder="Tu nombre" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-rose-300 focus:border-transparent outline-none text-sm text-gray-800 transition-all" />
            </div>
            <div>
              <label class="block text-xs font-medium tracking-wider uppercase text-gray-500 mb-2">Correo electrónico</label>
              <input type="email" id="rsvp-email" required placeholder="tu@email.com" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-rose-300 focus:border-transparent outline-none text-sm text-gray-800 transition-all" />
            </div>
            <div>
              <label class="block text-xs font-medium tracking-wider uppercase text-gray-500 mb-2">Número de invitados</label>
              <select id="rsvp-guests" class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-rose-300 focus:border-transparent outline-none text-sm text-gray-800 bg-white transition-all">
                <option value="1">Solo yo</option>
                <option value="2">2 personas</option>
                <option value="3">3 personas</option>
                <option value="4">4 personas</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium tracking-wider uppercase text-gray-500 mb-3">¿Asistirás?</label>
              <div class="flex gap-3">
                <label class="flex-1 flex items-center gap-3 p-3 border-2 border-gray-200 rounded-xl cursor-pointer has-[:checked]:border-rose-400 has-[:checked]:bg-rose-50 transition-all">
                  <input type="radio" name="attending" value="yes" class="accent-rose-500" checked /> <span class="text-sm text-gray-700">¡Con gusto!</span>
                </label>
                <label class="flex-1 flex items-center gap-3 p-3 border-2 border-gray-200 rounded-xl cursor-pointer has-[:checked]:border-rose-400 has-[:checked]:bg-rose-50 transition-all">
                  <input type="radio" name="attending" value="no" class="accent-rose-500" /> <span class="text-sm text-gray-700">No podré ir</span>
                </label>
              </div>
            </div>
            <div>
              <label class="block text-xs font-medium tracking-wider uppercase text-gray-500 mb-2">Mensaje especial (opcional)</label>
              <textarea id="rsvp-message" rows="3" placeholder="Un deseo o mensaje para los novios..." class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-rose-300 focus:border-transparent outline-none text-sm text-gray-800 resize-none transition-all"></textarea>
            </div>
            <button type="submit" class="w-full py-4 bg-gradient-to-r from-rose-400 to-pink-500 hover:from-rose-500 hover:to-pink-600 text-white font-medium rounded-xl transition-all hover:shadow-lg hover:shadow-rose-200 text-sm tracking-wider uppercase">
              Confirmar Asistencia
            </button>
          </form>

          <!-- Success State -->
          <div id="rsvp-success" class="hidden text-center py-8">
            <div class="w-16 h-16 bg-rose-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </div>
            <h3 class="text-2xl text-gray-800 mb-2" style="font-family:'Cormorant Garamond',serif; font-style:italic;">¡Gracias!</h3>
            <p class="text-gray-500 text-sm" id="rsvp-success-msg"></p>
          </div>
        </div>

        <!-- Quote -->
        <div class="text-center mt-12">
          <p class="text-gray-400 text-sm italic" style="font-family:'Cormorant Garamond',serif;">"El amor no mira con los ojos, sino con la mente."</p>
          <p class="text-gray-300 text-xs mt-2">— William Shakespeare</p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-10 bg-gray-900 text-center">
      <p class="text-gray-500 text-xs tracking-widest uppercase">María & Carlos · 15 de Septiembre 2025</p>
      <p class="text-gray-700 text-xs mt-2">Hecho con amor · Demo por <a href="https://adagi0.com" class="text-rose-400 hover:text-rose-300 transition-colors" target="_blank">AdagIO</a></p>
    </footer>
  </div>

  <script>
    // ── Countdown ─────────────────────────────────────────────────────────────
    const weddingDate = new Date('2025-09-15T16:00:00-06:00');
    function updateCountdown() {
      const now = new Date();
      const diff = weddingDate.getTime() - now.getTime();
      if (diff <= 0) {
        document.getElementById('countdown')!.innerHTML = '<span class="text-rose-200 text-xl tracking-wider">¡Hoy es el gran día! 🎊</span>';
        return;
      }
      const d = Math.floor(diff / 86400000);
      const h = Math.floor((diff % 86400000) / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      const set = (id: string, val: number) => {
        const el = document.getElementById(id);
        if (el) el.textContent = String(val).padStart(2, '0');
      };
      set('cd-days', d); set('cd-hours', h); set('cd-mins', m); set('cd-secs', s);
    }
    updateCountdown();
    setInterval(updateCountdown, 1000);

    // ── Falling petals ────────────────────────────────────────────────────────
    const canvas = document.getElementById('petalsCanvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    let W = 0, H = 0;
    const resize = () => { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; };
    resize();
    window.addEventListener('resize', resize);

    const petals: Array<{ x: number; y: number; r: number; vx: number; vy: number; rot: number; vr: number; alpha: number }> = [];
    const MAX_PETALS = 28;

    function createPetal() {
      return {
        x: Math.random() * W,
        y: -20,
        r: 4 + Math.random() * 6,
        vx: (Math.random() - 0.5) * 0.8,
        vy: 0.4 + Math.random() * 0.8,
        rot: Math.random() * Math.PI * 2,
        vr: (Math.random() - 0.5) * 0.04,
        alpha: 0.4 + Math.random() * 0.4,
      };
    }

    for (let i = 0; i < MAX_PETALS; i++) {
      const p = createPetal();
      p.y = Math.random() * H;
      petals.push(p);
    }

    function drawPetal(p: typeof petals[0]) {
      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(p.rot);
      ctx.globalAlpha = p.alpha;
      ctx.beginPath();
      ctx.ellipse(0, 0, p.r, p.r * 1.6, 0, 0, Math.PI * 2);
      ctx.fillStyle = '#fda4af';
      ctx.fill();
      ctx.restore();
    }

    function animatePetals() {
      ctx.clearRect(0, 0, W, H);
      for (let i = 0; i < petals.length; i++) {
        const p = petals[i];
        p.x += p.vx + Math.sin(Date.now() / 2000 + i) * 0.3;
        p.y += p.vy;
        p.rot += p.vr;
        if (p.y > H + 20) { petals[i] = createPetal(); }
        drawPetal(p);
      }
      requestAnimationFrame(animatePetals);
    }
    animatePetals();

    // ── Scroll reveal ─────────────────────────────────────────────────────────
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ── Gallery lightbox ──────────────────────────────────────────────────────
    const lb = document.getElementById('lightbox')!;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    const lbLabel = document.getElementById('lb-label')!;
    const lbClose = document.getElementById('lb-close')!;

    document.querySelectorAll('.gallery-item').forEach(item => {
      item.addEventListener('click', () => {
        const src = item.getAttribute('data-src') || '';
        const label = item.getAttribute('data-label') || '';
        lbImg.src = src;
        lbLabel.textContent = label;
        lb.style.opacity = '1';
        lb.style.pointerEvents = 'auto';
        document.body.style.overflow = 'hidden';
      });
    });

    const closeLb = () => {
      lb.style.opacity = '0';
      lb.style.pointerEvents = 'none';
      document.body.style.overflow = '';
    };
    lbClose.addEventListener('click', closeLb);
    lb.addEventListener('click', (e) => { if (e.target === lb) closeLb(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLb(); });

    // ── RSVP form ─────────────────────────────────────────────────────────────
    const form = document.getElementById('rsvp-form')!;
    const formWrap = document.getElementById('rsvp-form-wrap')!;
    const successDiv = document.getElementById('rsvp-success')!;
    const successMsg = document.getElementById('rsvp-success-msg')!;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = (document.getElementById('rsvp-name') as HTMLInputElement).value;
      const attending = (document.querySelector('input[name="attending"]:checked') as HTMLInputElement)?.value;

      // Simulate submission (in production, send to Netlify Forms / API)
      setTimeout(() => {
        form.style.display = 'none';
        successDiv.classList.remove('hidden');
        successMsg.textContent = attending === 'yes'
          ? `¡Perfecto ${name}! Estamos muy emocionados de verte. Recibirás más detalles por correo.`
          : `Gracias ${name} por avisarnos. Los llevaremos en el corazón ese día.`;
      }, 400);
    });
  </script>

  <style>
    @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fadeIn { animation: fadeIn 1.2s ease-out forwards; }

    .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
    .reveal.revealed { opacity: 1; transform: translateY(0); }

    html { scroll-behavior: smooth; }
    * { box-sizing: border-box; }
  </style>
</DemoLayout>
