---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Bar from '../components/bar.astro';

const settings = await getEntry('settings', 'general');
const waPhone = settings?.data.whatsapp ?? '5215512345678';
---

<Layout
  title="Carrito | AdagIO"
  description="Revisa tu carrito de productos AdagIO y finaliza tu pedido por WhatsApp o formulario."
>
  <Bar />

  <main class="w-full bg-gray-50 min-h-[70vh] py-12 px-4">
    <div class="max-w-5xl mx-auto">

      <div class="flex items-center justify-between mb-10">
        <h1 class="text-3xl sm:text-4xl font-black text-gray-900">Tu carrito</h1>
        <a href="/productos" class="text-sm font-semibold text-[#123472] hover:underline flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Seguir comprando
        </a>
      </div>

      <!-- Empty state -->
      <div id="cart-empty" class="hidden flex-col items-center justify-center py-24 text-center">
        <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mb-6">
          <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold text-gray-900 mb-2">Tu carrito está vacío</h2>
        <p class="text-gray-500 text-sm mb-8 max-w-xs">Explora nuestro catálogo de kiosks, dispositivos IoT y accesorios.</p>
        <a href="/productos" class="bg-gray-900 hover:bg-[#123472] text-white font-bold px-8 py-3.5 rounded-2xl transition-colors">
          Ver productos
        </a>
      </div>

      <!-- Cart content -->
      <div id="cart-content" class="hidden grid lg:grid-cols-3 gap-8 items-start">

        <!-- Items list -->
        <div id="cart-items" class="lg:col-span-2 flex flex-col gap-4"></div>

        <!-- Summary -->
        <div class="bg-white rounded-3xl border border-gray-100 shadow-lg p-6 lg:sticky lg:top-24">
          <h2 class="text-lg font-bold text-gray-900 mb-6">Resumen del pedido</h2>

          <div class="space-y-3 mb-6 pb-6 border-b border-gray-100 text-sm">
            <div class="flex justify-between text-gray-600">
              <span>Subtotal</span>
              <span id="cart-subtotal" class="font-semibold text-gray-900">$0</span>
            </div>
            <div class="flex justify-between text-gray-600">
              <span>Envío</span>
              <span class="font-semibold text-green-600">Incluido</span>
            </div>
            <div class="flex justify-between text-gray-600">
              <span>Instalación</span>
              <span class="font-semibold text-green-600">Incluida</span>
            </div>
          </div>

          <div class="flex justify-between items-end mb-8">
            <span class="text-gray-500 text-sm">Total estimado</span>
            <span id="cart-total" class="text-3xl font-black text-gray-900">$0</span>
          </div>

          <div class="flex flex-col gap-3">
            <a
              id="checkout-wa"
              href="#"
              data-phone={waPhone}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1fb858] text-white font-bold py-4 rounded-2xl transition-colors"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Pedir por WhatsApp
            </a>
            <button
              id="checkout-form-btn"
              class="flex items-center justify-center gap-2 bg-gray-900 hover:bg-[#123472] text-white font-bold py-4 rounded-2xl transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Pedir por correo
            </button>
            <button
              id="cart-clear"
              class="text-xs text-gray-400 hover:text-red-500 transition-colors py-1"
            >
              Vaciar carrito
            </button>
          </div>

          <p class="text-[11px] text-gray-400 mt-6 leading-relaxed">
            Los precios son estimados en MXN. Al enviar tu pedido un asesor te contactará para confirmar disponibilidad, forma de pago y tiempos de entrega.
          </p>
        </div>
      </div>

      <!-- Order form modal -->
      <div id="order-modal" class="hidden fixed inset-0 z-[200] items-center justify-center p-4">
        <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="order-modal-bg"></div>
        <div class="relative bg-white rounded-3xl shadow-2xl w-full max-w-md p-8 max-h-[90vh] overflow-y-auto">
          <button id="order-modal-close" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 text-gray-400" aria-label="Cerrar">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
          <h3 class="text-xl font-bold text-gray-900 mb-1">Finalizar pedido</h3>
          <p class="text-gray-500 text-sm mb-6">Te contactaremos en menos de 24 horas hábiles.</p>

          <form name="Pedido" method="POST" data-netlify="true" id="order-form" class="flex flex-col gap-4">
            <input type="hidden" name="form-name" value="Pedido" />
            <input type="hidden" name="Productos" id="order-products" />
            <input type="hidden" name="Total" id="order-total" />
            <div class="flex flex-col gap-1.5">
              <label for="order-name" class="text-sm font-medium text-gray-700">Nombre completo *</label>
              <input required type="text" id="order-name" name="Nombre" class="bg-gray-50 border border-gray-200 rounded-xl p-3 text-sm focus:outline-none focus:border-[#123472]" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="order-email" class="text-sm font-medium text-gray-700">Correo electrónico *</label>
              <input required type="email" id="order-email" name="Correo" class="bg-gray-50 border border-gray-200 rounded-xl p-3 text-sm focus:outline-none focus:border-[#123472]" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="order-phone" class="text-sm font-medium text-gray-700">Teléfono *</label>
              <input required type="tel" id="order-phone" name="Telefono" class="bg-gray-50 border border-gray-200 rounded-xl p-3 text-sm focus:outline-none focus:border-[#123472]" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="order-notes" class="text-sm font-medium text-gray-700">Notas (opcional)</label>
              <textarea id="order-notes" name="Notas" class="bg-gray-50 border border-gray-200 rounded-xl p-3 text-sm h-20 resize-none focus:outline-none focus:border-[#123472]"></textarea>
            </div>
            <button type="submit" class="bg-gray-900 hover:bg-[#123472] text-white font-bold py-3.5 rounded-2xl transition-colors mt-2">
              Enviar pedido
            </button>
          </form>
        </div>
      </div>

      <!-- Success banner -->
      <div id="order-success" class="hidden mt-8 bg-green-50 border border-green-200 rounded-2xl p-6 text-center">
        <p class="text-green-800 font-semibold">✓ ¡Pedido enviado! Te contactaremos pronto para confirmar los detalles.</p>
      </div>

    </div>
  </main>
</Layout>

<script>
  import { getCart, setQty, removeFromCart, clearCart, cartTotal, formatMXN, buildWhatsAppOrder } from '../utils/cart';

  const elEmpty   = document.getElementById('cart-empty')!;
  const elContent = document.getElementById('cart-content')!;
  const elItems   = document.getElementById('cart-items')!;
  const elSub     = document.getElementById('cart-subtotal')!;
  const elTotal   = document.getElementById('cart-total')!;
  const elWA      = document.getElementById('checkout-wa') as HTMLAnchorElement;

  function render() {
    const items = getCart();
    const empty = items.length === 0;

    elEmpty.classList.toggle('hidden', !empty);
    elEmpty.classList.toggle('flex',   empty);
    elContent.classList.toggle('hidden', empty);
    elContent.classList.toggle('grid',  !empty);
    if (empty) return;

    elItems.innerHTML = items.map(i => `
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 flex items-center gap-4" data-id="${i.id}">
        <div class="w-16 h-16 shrink-0 rounded-xl bg-gradient-to-br ${i.gradient} flex items-center justify-center">
          <svg class="w-8 h-8 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">${i.category}</span>
          <h3 class="font-bold text-gray-900 text-sm truncate">${i.name}</h3>
          <p class="text-gray-500 text-xs mt-0.5">$${i.priceLabel} MXN c/u</p>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <button class="qty-btn w-7 h-7 rounded-lg border border-gray-200 hover:border-gray-400 text-gray-600 font-bold text-sm" data-action="dec">−</button>
          <span class="w-7 text-center text-sm font-bold text-gray-900">${i.qty}</span>
          <button class="qty-btn w-7 h-7 rounded-lg border border-gray-200 hover:border-gray-400 text-gray-600 font-bold text-sm" data-action="inc">+</button>
        </div>
        <div class="text-right shrink-0 hidden sm:block w-24">
          <p class="font-black text-gray-900 text-sm">${formatMXN(i.price * i.qty)}</p>
        </div>
        <button class="remove-btn shrink-0 w-8 h-8 flex items-center justify-center rounded-lg text-gray-300 hover:text-red-500 hover:bg-red-50 transition-colors" aria-label="Quitar">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        </button>
      </div>
    `).join('');

    const total = cartTotal();
    elSub.textContent   = formatMXN(total);
    elTotal.textContent = formatMXN(total);
    elWA.href = `https://wa.me/${elWA.dataset.phone}?text=${encodeURIComponent(buildWhatsAppOrder())}`;

    // Wire qty/remove buttons
    elItems.querySelectorAll<HTMLElement>('[data-id]').forEach(row => {
      const id = row.dataset.id!;
      const item = items.find(x => x.id === id)!;
      row.querySelectorAll<HTMLButtonElement>('.qty-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          setQty(id, btn.dataset.action === 'inc' ? item.qty + 1 : item.qty - 1);
        });
      });
      row.querySelector('.remove-btn')?.addEventListener('click', () => removeFromCart(id));
    });
  }

  render();
  window.addEventListener('cart:updated', render);

  /* Clear cart */
  document.getElementById('cart-clear')?.addEventListener('click', () => {
    if (confirm('¿Vaciar el carrito?')) clearCart();
  });

  /* Order modal */
  const modal = document.getElementById('order-modal')!;
  const openModal = () => {
    const items = getCart();
    (document.getElementById('order-products') as HTMLInputElement).value =
      items.map(i => `${i.name} x${i.qty}`).join(' | ');
    (document.getElementById('order-total') as HTMLInputElement).value = formatMXN(cartTotal());
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  };
  const closeModal = () => {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  };
  document.getElementById('checkout-form-btn')?.addEventListener('click', openModal);
  document.getElementById('order-modal-close')?.addEventListener('click', closeModal);
  document.getElementById('order-modal-bg')?.addEventListener('click', closeModal);

  /* AJAX submit → success (funciona en local y producción) */
  const orderForm = document.getElementById('order-form') as HTMLFormElement | null;
  orderForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(orderForm);
    try {
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as any).toString(),
      });
    } catch { /* Netlify Forms procesa en producción; en local solo confirmamos */ }
    closeModal();
    clearCart();
    document.getElementById('order-success')?.classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
